{
  "name": "gainster",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @gainster/api dev",
    "dev:web": "pnpm --filter @gainster/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @gainster/api build",
    "build:web": "pnpm --filter @gainster/web build",
    "build:market-data": "pnpm --filter @gainster/market-data build",
    "smoke:market-data": "pnpm --filter @gainster/market-data smoke",
    "build:db": "pnpm --filter @gainster/db build",
    "db:generate": "pnpm --filter @gainster/db db:generate",
    "db:migrate": "pnpm --filter @gainster/db db:migrate",
    "db:studio": "pnpm --filter @gainster/db db:studio"
  }
}
